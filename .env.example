# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=home

# 单用户固定 ID（P2 无登录方案 A）
SINGLE_USER_ID=00000000-0000-0000-0000-000000000001

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODEL_DAY7=deepseek-reasoner

# DashScope (阿里) — 多用途共用一个 API Key
# Vision (V0.5 拍照分析) / Style Audit / Content Audit / ASR / 图像生成都走这个
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-plus

# V0.6.1: ASR (Paraformer-realtime, WebSocket 流式协议)
# 注意：base url 是 wss:// 而不是 https://
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
DASHSCOPE_ASR_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference/

# V0.6.1: 图像生成（通义万相）
DASHSCOPE_IMAGEGEN_MODEL=wanx2.1-t2i-turbo
DASHSCOPE_IMAGEGEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis

# V0.6.1+: 图像生成 B 路（MiniMax image-01）— 与 DashScope 并行测试
MINIMAX_API_KEY=
MINIMAX_IMAGEGEN_MODEL=image-01
MINIMAX_IMAGEGEN_BASE_URL=https://api.minimaxi.com/v1/image_generation

# Storage
UPLOAD_DIR=uploads

# Feature flags
ENABLE_DEV_JPG_PICKER=true
LLM_LOG_TO_DB=true

# Cookie secure flag：未上 HTTPS 的临时部署阶段必须设 0，
# 否则浏览器在 HTTP 页面下会丢弃 Set-Cookie 导致全局 401。
# 上 HTTPS 后请改回 1（或删除此行，默认生产开 secure）。
COOKIE_SECURE=1
