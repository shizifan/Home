# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=home

# 单用户固定 ID（P2 无登录方案 A）
SINGLE_USER_ID=00000000-0000-0000-0000-000000000001

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODEL_DAY7=deepseek-reasoner

# DashScope Qwen-VL (Vision)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-plus

# Storage
UPLOAD_DIR=uploads

# Feature flags
ENABLE_DEV_JPG_PICKER=true
LLM_LOG_TO_DB=true
